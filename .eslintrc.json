{
  "root": true,
  "env": {
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^next$|^_$" }]
  },
  "overrides": [
    {
      "files": ["public/**/*.js"],
      "env": { "browser": true }
    }
  ]
}
