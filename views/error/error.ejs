<%- include('../partials/header', { title: title || 'Error' }) %>

  <div class="text-center py-5">
    <i class="bi bi-exclamation-octagon empty-state-icon text-danger"></i>
    <h1 class="display-4 mt-3 mb-2"><%= typeof statusCode !== 'undefined' ? statusCode : 'Error' %></h1>
    <p class="text-muted"><%= typeof message !== 'undefined' ? message : 'Something went wrong.' %></p>
    <a href="/" class="btn btn-dark mt-2">Go Home</a>
  </div>

<%- include('../partials/footer') %>
