<%- include('../partials/header', { title: 'Dashboard', active: 'dashboard' }) %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Dashboard</h1>
    <a href="/contacts/new" class="btn btn-dark">
      <i class="bi bi-plus-lg me-1"></i>Add Contact
    </a>
  </div>

  <!-- Stat cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body d-flex align-items-center">
          <span class="stat-icon primary"><i class="bi bi-people"></i></span>
          <div class="ms-3">
            <div class="stat-label">Total Contacts</div>
            <div class="stat-value"><%= stats.total %></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body d-flex align-items-center">
          <span class="stat-icon warning"><i class="bi bi-star-fill"></i></span>
          <div class="ms-3">
            <div class="stat-label">Favorites</div>
            <div class="stat-value"><%= stats.favorites %></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body d-flex align-items-center">
          <span class="stat-icon muted"><i class="bi bi-envelope"></i></span>
          <div class="ms-3">
            <div class="stat-label">With Email</div>
            <div class="stat-value"><%= stats.withEmail %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recently added contacts -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
      <span class="fw-semibold"><i class="bi bi-clock me-1"></i>Recently Added Contacts</span>
      <a href="/contacts" class="small">View all</a>
    </div>
    <div class="card-body">
      <% if (recentContacts.length === 0) { %>
        <p class="text-muted mb-0">No contacts yet. <a href="/contacts/new">Add your first contact</a>.</p>
      <% } else { %>
        <ul class="list-group list-group-flush">
          <% recentContacts.forEach(function (c) { %>
            <li class="list-group-item d-flex align-items-center px-0 border-0">
              <img
                src="<%= c.imageUrl %>"
                alt="<%= c.fullName %>"
                class="rounded-circle me-3"
                width="40"
                height="40"
              />
              <div class="flex-grow-1">
                <a href="/contacts/<%= c._id %>" class="fw-semibold text-decoration-none text-dark">
                  <%= c.fullName %>
                </a>
                <div class="small text-muted">
                  <%= c.company ? c.company + (c.jobTitle ? ' · ' + c.jobTitle : '') : (c.jobTitle || 'No company') %>
                </div>
              </div>
              <% if (c.favorite) { %><i class="bi bi-star-fill text-warning me-2"></i><% } %>
              <a href="/contacts/<%= c._id %>" class="btn btn-sm btn-outline-dark">
                <i class="bi bi-eye"></i>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
  </div>

<%- include('../partials/footer') %>
