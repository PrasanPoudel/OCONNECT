<%- include('../partials/header', { title: contact.fullName, active: 'contacts' }) %>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-4 flex-wrap gap-3">
            <img
              src="<%= contact.imageUrl %>"
              alt="<%= contact.fullName %>"
              class="rounded-circle"
              width="96"
              height="96"
            />
            <div class="flex-grow-1">
              <h1 class="h3 mb-0">
                <%= contact.fullName %>
                <% if (contact.favorite) { %><i class="bi bi-star-fill text-warning ms-1"></i><% } %>
              </h1>
              <div class="text-muted">
                <%= contact.jobTitle ? contact.jobTitle + (contact.company ? ' at ' + contact.company : '') : (contact.company || 'No title / company') %>
              </div>
            </div>
            <div class="d-flex gap-2">
              <a href="/contacts/<%= contact._id %>/edit" class="btn btn-outline-dark btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
              </a>
              <form action="/contacts/<%= contact._id %>?_method=DELETE" method="POST" class="d-inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-outline-danger btn-sm" data-confirm="Delete this contact?">
                  <i class="bi bi-trash me-1"></i>Delete
                </button>
              </form>
            </div>
          </div>

          <table class="table table-borderless align-middle">
            <tbody>
              <% if (contact.phone) { %>
              <tr>
                <th style="width: 180px;"><i class="bi bi-telephone me-2"></i>Phone</th>
                <td><a href="tel:<%= contact.phone %>" class="text-decoration-none"><%= contact.phone %></a></td>
              </tr>
              <% } %>
              <% if (contact.email) { %>
              <tr>
                <th><i class="bi bi-envelope me-2"></i>Email</th>
                <td><a href="mailto:<%= contact.email %>" class="text-decoration-none"><%= contact.email %></a></td>
              </tr>
              <% } %>
              <% if (contact.company) { %>
              <tr>
                <th><i class="bi bi-building me-2"></i>Company</th>
                <td><%= contact.company %></td>
              </tr>
              <% } %>
              <% if (contact.jobTitle) { %>
              <tr>
                <th><i class="bi bi-briefcase me-2"></i>Job Title</th>
                <td><%= contact.jobTitle %></td>
              </tr>
              <% } %>
              <% if (contact.website) { %>
              <tr>
                <th><i class="bi bi-globe me-2"></i>Website</th>
                <td><a href="<%= contact.website %>" target="_blank" rel="noopener" class="text-decoration-none"><%= contact.website %></a></td>
              </tr>
              <% } %>
              <% if (contact.address) { %>
              <tr>
                <th><i class="bi bi-geo-alt me-2"></i>Address</th>
                <td><%= contact.address %></td>
              </tr>
              <% } %>
              <tr>
                <th><i class="bi bi-star me-2"></i>Favorite</th>
                <td><%= contact.favorite ? 'Yes' : 'No' %></td>
              </tr>
            </tbody>
          </table>

          <% if (contact.notes) { %>
            <div class="mt-3">
              <h2 class="h6 text-muted">Notes</h2>
              <p class="mb-0" style="white-space: pre-wrap;"><%= contact.notes %></p>
            </div>
          <% } %>

          <hr class="my-4" />
          <div class="small text-muted mb-3">
            Added <%= contact.createdAt.toLocaleDateString() %> &middot;
            Updated <%= contact.updatedAt.toLocaleDateString() %>
          </div>

          <div class="d-flex gap-2 flex-wrap">
            <a href="/contacts" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-arrow-left me-1"></i>Back to contacts
            </a>
            <form action="/contacts/<%= contact._id %>/favorite" method="POST" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-star me-1"></i><%= contact.favorite ? 'Unfavorite' : 'Add to favorites' %>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

<%- include('../partials/footer') %>
