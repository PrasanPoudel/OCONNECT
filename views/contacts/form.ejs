<%- include('../partials/header', { title: isEdit ? 'Edit Contact' : 'Add Contact', active: 'contacts' }) %>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <h1 class="h4 mb-4"><%= isEdit ? 'Edit Contact' : 'Add Contact' %></h1>

          <% if (typeof errors !== 'undefined' && errors.length) { %>
            <div class="alert alert-danger">
              <ul class="mb-0 ps-3">
                <% errors.forEach(function (e) { %><li><%= e.msg %></li><% }); %>
              </ul>
            </div>
          <% } %>

          <form
            action="<%= isEdit ? '/contacts/' + contact._id : '/contacts' %>?_method=<%= isEdit ? 'PUT' : 'POST' %>"
            method="POST"
            enctype="multipart/form-data"
            novalidate
          >
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

            <!-- Profile image -->
            <div class="text-center mb-4">
              <img
                id="imagePreview"
                src="<%= isEdit && contact.imageUrl ? contact.imageUrl : defaultAvatar %>"
                alt="Profile preview"
                class="rounded-circle"
                width="125"
                height="125"
              />
              <div class="mt-3">
                <label for="profileImage" class="btn btn-outline-dark btn-sm">
                  <i class="bi bi-upload me-1"></i>Upload Photo
                </label>
                <input type="file" id="profileImage" name="profileImage" accept="image/*" class="d-none" />
              </div>
              <div class="form-text">JPG/PNG, max 5MB. Leave empty to keep the current image.</div>
            </div>

            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Full Name <span class="text-danger">*</span></label>
                <input autocomplete="off" type="text" class="form-control" name="fullName" required
                  value="<%= contact && contact.fullName ? contact.fullName : '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Phone Number</label>
                <input autocomplete="off" type="text" class="form-control" name="phone"
                  value="<%= contact && contact.phone ? contact.phone : '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Email</label>
                <input autocomplete="off" type="email" class="form-control" name="email"
                  value="<%= contact && contact.email ? contact.email : '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Company</label>
                <input autocomplete="off" type="text" class="form-control" name="company"
                  value="<%= contact && contact.company ? contact.company : '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Job Title</label>
                <input autocomplete="off" type="text" class="form-control" name="jobTitle"
                  value="<%= contact && contact.jobTitle ? contact.jobTitle : '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Website</label>
                <input autocomplete="off" type="url" class="form-control" name="website"
                  value="<%= contact && contact.website ? contact.website : '' %>" />
              </div>
              <div class="col-12">
                <label class="form-label">Address</label>
                <input autocomplete="off" type="text" class="form-control" name="address"
                  value="<%= contact && contact.address ? contact.address : '' %>" />
              </div>
              <div class="col-12">
                <label class="form-label">Notes</label>
                <textarea class="form-control" name="notes" rows="3"><%= contact && contact.notes ? contact.notes : '' %></textarea>
              </div>
              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="favorite" value="on" id="favorite"
                    <%= contact && contact.favorite ? 'checked' : '' %> />
                  <label class="form-check-label" for="favorite">
                    <i class="bi bi-star-fill text-warning"></i> Mark as favorite
                  </label>
                </div>
              </div>
            </div>

            <div class="d-flex gap-2 mt-4">
              <button type="submit" class="btn btn-dark">
                <i class="bi bi-save me-1"></i><%= isEdit ? 'Update Contact' : 'Save Contact' %>
              </button>
              <a href="/contacts" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

<%- include('../partials/footer', { extraScripts: `
  <script>
    const input = document.getElementById('profileImage');
    const preview = document.getElementById('imagePreview');
    input.addEventListener('change', function () {
      const file = this.files && this.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (e) => { preview.src = e.target.result; };
        reader.readAsDataURL(file);
      }
    });
  </script>
` }) %>
